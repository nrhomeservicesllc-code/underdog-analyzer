# ── Odds data ────────────────────────────────────────────────────────────────
# Your odds-api.io API key
ODDS_API_KEY=""

# ── Auth (required for production) ──────────────────────────────────────────
# Any long random string — run: openssl rand -hex 32
AUTH_SECRET=""
# Admin login (defaults: sharpdogadmin / Zabdiel2025!)
# To change the password: generate a bcrypt hash and set it here
ADMIN_USERNAME="sharpdogadmin"
ADMIN_PASSWORD_HASH=""

# ── User storage (required for real signups to persist) ─────────────────────
# Create a free Upstash Redis database (or Vercel KV) and paste its REST creds.
# Without these, accounts reset on every redeploy (demo mode).
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ── Stripe subscriptions (enables the paywall when all three are set) ───────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
# Display prices on the subscribe page (cosmetic only — Stripe charges the real price)
NEXT_PUBLIC_PRICE_MONTHLY_DISPLAY="$9.99"
NEXT_PUBLIC_PRICE_YEARLY_DISPLAY="$79.99"

# ── Site ─────────────────────────────────────────────────────────────────────
# Your live URL (used for social share cards)
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
